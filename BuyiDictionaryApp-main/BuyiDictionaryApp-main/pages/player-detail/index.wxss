/* 播放器页青花瓷风格样式 */

.player-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  color: #fff;
}

.bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  filter: blur(40rpx);
  transform: scale(1.1);
  z-index: 0;
}

.bg-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(18, 59, 107, 0.9) 0%, rgba(22, 100, 217, 0.7) 100%);
  z-index: 1;
}

.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  padding: 80rpx 40rpx 120rpx;
  box-sizing: border-box;
}

/* 顶部信息 */
.top {
  text-align: center;
  margin-top: 40rpx;
}
.song-title {
  color: #fff;
  margin-bottom: 12rpx;
  display: block;
}
.song-artist {
  color: rgba(255, 255, 255, 0.7);
  display: block;
}

/* 唱片封面 */
.cover-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.cover-border {
  width: 560rpx;
  height: 560rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 32rpx 64rpx rgba(0,0,0,0.3);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}
.cover {
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  border: 12rpx solid #111; /* 模拟黑胶唱片边距 */
}
.spin {
  animation: spin 12s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0); }
  to { transform: rotate(360deg); }
}

/* 简版歌词框 */
.lyric-box {
  height: 120rpx;
  text-align: center;
  margin-bottom: 60rpx;
}
.lyric-text {
  display: block;
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}

/* 控制器 */
.controls {
  width: 100%;
  padding: 0 20rpx;
}
.progress {
  margin: 0;
}
.time-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: -12rpx;
  margin-bottom: 40rpx;
}

.btn-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60rpx;
}
.ctrl-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #fff;
  transition: transform 0.2s;
}
.ctrl-btn:active {
  transform: scale(0.9);
}
.sub-btn {
  width: 96rpx;
  height: 96rpx;
  font-size: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}
.play-btn {
  width: 144rpx;
  height: 144rpx;
  font-size: 64rpx;
  background: var(--color-card-bg);
  color: var(--color-primary-dark);
  box-shadow: 0 16rpx 32rpx rgba(0,0,0,0.2);
}
