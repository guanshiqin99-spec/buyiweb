# ===========================================
# 布依族词典 - 整个项目根目录 .gitignore
# 仓库已设为私密,但仍排除以下敏感/无用文件
# ===========================================

# ---------- 敏感信息(绝对排除) ----------
# 账号密码密钥文件夹
buyi-密码与分析/

# 环境变量配置(含数据库连接、JWT 密钥等)
.env
.env.local
.env.*.local
.env.example
**/.env
**/.env.local
**/.env.*.local

# Security: credential-bearing scripts
BuyiDictionaryApp-main/BuyiDictionaryApp-main/backend/reset_admin.js
BuyiDictionaryApp-main/BuyiDictionaryApp-main/backend/show_tables.js
BuyiDictionaryApp-main/BuyiDictionaryApp-main/backend/upload.js

# ---------- 日志文件 ----------
*.log
logs/
**/logs/
server.log
server-live.log
server-live.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- 浏览器/IDE 运行时数据 ----------
# edge-profile 是浏览器用户数据(Cookies、历史等),不应上传
design_concepts/ui-audit-2026-07-14/edge-profile/

# Trae IDE 运行时缓存(保留 .trae/documents 和 .trae/specs 文档)
.trae/cache/
.trae/tmp/

# ---------- 系统文件 ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- 编辑器配置 ----------
# 注意:保留 .vscode/mcp.json 等共享配置,只排除个人设置
**/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ---------- 依赖目录 ----------
# node_modules 可由 package.json + package-lock.json 通过 npm install 还原,不入库
node_modules/
**/node_modules/

# ---------- 构建产物 ----------
# dist 通常不入库,但若需演示可手动 add
# 此处保留各子项目的 dist 以便演示

# ---------- 数据库运行时文件 ----------
# 保留 buyi_dictionary.db 作为种子数据,但排除运行时临时库
*-test.sqlite
migration-test.sqlite

# ---------- 大文件(超过 GitHub 100MB 限制) ----------
*.zip
*.tar.gz
*.rar
*.7z
*.exe
*.msi
*.dmg
*.iso

# ---------- 构建缓存 ----------
.vite/
.wrangler/
**/.vite/
**/.wrangler/

# ---------- 环境变量(生产环境配置含密钥) ----------
.env.production
**/.env.production

# ---------- 临时 JSON 数据 ----------
songs_response.json

# ---------- 备份目录 ----------
.git_backup/
original_assets_backup/

# ---------- 临时文件 ----------
*.tmp
*.bak
*.swp
*~

# Local review quarantine (keep locally, never commit)
_trash_review/

# ---------- Python 脚本(暂不推送) ----------
# 用户偏好:暂不推送 Python 脚本,仅保留本地使用
*.py
**/*.py

# Python 运行时缓存
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# ---------- 临时/误生成文件 ----------
$null
$null.*

# ---------- 本地构建脚本(不入库) ----------
sealos-build.bat

# ---------- TRAE IDE 运行时(保留 specs 文档) ----------
.trae/skills/

# ---------- 后端运行时上传文件(不入库) ----------
BuyiDictionaryApp-main/BuyiDictionaryApp-main/backend/uploads/
