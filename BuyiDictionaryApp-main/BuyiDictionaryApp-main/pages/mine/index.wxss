/* 青瓷个人空间风格样式 */

.mine-page {
  position: relative;
  z-index: 1;
  padding-bottom: 240rpx; /* 给悬浮TabBar留足空间 */
}

/* 背景系统 */
.mine-bg-texture {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 600rpx;
  background: radial-gradient(circle at 100% 0, rgba(22, 100, 217, 0.05) 0%, transparent 60%),
              radial-gradient(circle at 0% 20%, rgba(90, 169, 255, 0.05) 0%, transparent 50%);
  z-index: -1;
}

.page.dark .mine-bg-texture {
  background: radial-gradient(circle at 100% 0, rgba(22, 100, 217, 0.1) 0%, transparent 60%),
              radial-gradient(circle at 0% 20%, rgba(90, 169, 255, 0.08) 0%, transparent 50%);
}

.mine-bg-watermark {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 800rpx;
  background: radial-gradient(ellipse at 50% 100%, rgba(22, 100, 217, 0.03) 0%, transparent 60%);
  z-index: -1;
}

.page.dark .mine-bg-watermark {
  background: radial-gradient(ellipse at 50% 100%, rgba(22, 100, 217, 0.08) 0%, transparent 60%);
}

/* 瓷釉渐变用户�?*/
.user-card-premium {
  position: relative;
  border-radius: 36rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 48rpx -12rpx rgba(78, 127, 198, 0.3);
  overflow: hidden;
  background: linear-gradient(135deg, #5D8FD6 0%, #4E7FC6 40%, #7FA9E4 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.page.dark .user-card-premium {
  background: linear-gradient(135deg, #243B5C 0%, #172D4C 40%, #2A456C 100%);
  box-shadow: 0 16rpx 48rpx -12rpx rgba(0, 0, 0, 0.6);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.user-card-texture {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.15) 0%, transparent 40%),
                    repeating-radial-gradient(circle at 20% 80%, rgba(255,255,255,0.03) 0%, rgba(255,255,255,0.03) 1px, transparent 2px, transparent 100%);
  z-index: 1;
}

.user-card-content {
  position: relative;
  z-index: 2;
  display: flex;
  align-items: center;
}

/* 头像：青花外�?*/
.avatar-wrapper {
  position: relative;
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  margin-right: 32rpx;
  background: #F4F8FF; /* 玉石白底 */
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 12rpx rgba(22, 100, 217, 0.1);
  padding: 8rpx;
}

.page.dark .avatar-wrapper {
  background: rgba(255, 255, 255, 0.1);
  box-shadow: inset 0 0 12rpx rgba(0, 0, 0, 0.2);
}

.avatar-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2rpx dashed rgba(22, 100, 217, 0.4);
  transform: rotate(15deg);
}

.page.dark .avatar-ring {
  border-color: rgba(255, 255, 255, 0.2);
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
}

.user-avatar-image {
  border-radius: 50% !important;
  border: 4rpx solid #1664D9 !important; /* 青花瓷描边 */
}

.page.dark .avatar {
  border-color: rgba(255, 255, 255, 0.2);
}

/* 用户信息 */
.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.user-nickname-text {
  color: #1A3A69 !important; /* 深靛蓝文字 */
  text-shadow: none !important;
}

.sync-status {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sync-icon {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-right: 8rpx;
}

.user-status {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  opacity: 0.9;
}

.user-desc {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  background: rgba(255,255,255,0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.desc-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

/* 瓷片统计�?*/
.porcelain-stat-card {
  display: flex;
  align-items: center;
  padding: 36rpx 20rpx;
  margin-bottom: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx -4rpx rgba(22, 100, 217, 0.05);
}

.page.dark .porcelain-stat-card {
  box-shadow: 0 4rpx 20rpx -4rpx rgba(0, 0, 0, 0.5);
  background: var(--color-card-bg);
}

.stat-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F0F6FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  border: 1rpx solid #E6F0FF;
}

.page.dark .stat-icon-wrap {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.05);
}

.stat-icon {
  width: 40rpx;
  height: 40rpx;
}

.stat-data {
  display: flex;
  flex-direction: column;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #123B6B; /* 深靛�?*/
  margin-bottom: 4rpx;
}

.page.dark .stat-num {
  color: #EDF5FF;
}

.stat-title {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.stat-divider-cloud {
  width: 2rpx;
  height: 60rpx;
  background: linear-gradient(to bottom, transparent, rgba(22, 100, 217, 0.15), transparent);
}

.page.dark .stat-divider-cloud {
  background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.1), transparent);
}

/* 学习成长模块 */
.growth-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(22, 100, 217, 0.03);
  border: 1rpx solid rgba(22, 100, 217, 0.05); /* 更轻阴影，用细边�?*/
}

.page.dark .growth-card {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  background: var(--color-card-bg);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.growth-content {
  display: flex;
  justify-content: space-between;
}

.growth-item {
  flex: 1;
  background: linear-gradient(to bottom right, #FAFCFF, #F4F8FF);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-right: 16rpx;
  border: 1rpx solid #EBF2FF;
  position: relative;
  overflow: hidden;
}

.page.dark .growth-item {
  background: linear-gradient(to bottom right, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  border-color: rgba(255, 255, 255, 0.05);
}

.growth-item:last-child {
  margin-right: 0;
}

.growth-icon {
  position: absolute;
  right: -10rpx;
  top: 16rpx;
  width: 100rpx;
  height: 100rpx;
  opacity: 0.08;
}

.growth-label {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
}

.growth-value {
  margin-bottom: 8rpx;
}

.growth-num {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-right: 6rpx;
}

.page.dark .growth-num {
  color: #EDF5FF;
}

.growth-unit {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.growth-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

/* 文化感功能菜�?*/
.culture-menu-card {
  padding: 16rpx 40rpx;
  border-radius: 24rpx;
  box-shadow: none;
  border: 1rpx solid rgba(22, 100, 217, 0.08);
}

.page.dark .culture-menu-card {
  background: var(--color-card-bg);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F4F8FF;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
  border: 1px solid #EBF2FF;
}

.page.dark .menu-icon-wrap {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.05);
}

.menu-icon {
  width: 36rpx;
  height: 36rpx;
}

.menu-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.menu-text {
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.menu-sub {
  font-size: 22rpx;
}

.menu-arrow {
  color: #A0B8D4; /* 更柔和的青花辅色 */
  font-family: monospace;
  font-size: 28rpx;
}

.page.dark .menu-arrow {
  color: rgba(255, 255, 255, 0.4);
}

.menu-divider-fade {
  height: 2rpx;
  background: linear-gradient(to right, transparent, rgba(22, 100, 217, 0.08) 20%, rgba(22, 100, 217, 0.08) 80%, transparent);
}

.page.dark .menu-divider-fade {
  background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.05) 20%, rgba(255, 255, 255, 0.05) 80%, transparent);
}

/* 底部签句 */
.culture-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 0 64rpx 0;
  opacity: 0.6;
}

.quote-mark {
  font-family: serif;
  font-size: 40rpx;
  color: var(--color-primary);
  margin-right: 12rpx;
  transform: translateY(-8rpx);
}

.quote-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

.quote-seal {
  font-size: 20rpx;
  color: #D9534F; /* 印泥�?*/
  margin-left: 16rpx;
  border: 2rpx solid #D9534F;
  border-radius: 4rpx;
  padding: 2rpx 6rpx;
  font-weight: bold;
}



