          <Property name="textColor">#173B6C</Property>
          <Property name="textSize">18</Property>
          <Property name="fontWeight">bold</Property>
        </Element>
        <Element id="Home_Banner_Card_Desc" type="Native.Text">
          <Property name="box">40,470,310,40</Property>
          <Property name="textContent">"你好" -> "Xiongq yul" (音译)\n每天积累，感受布依族文化之美。</Property>
          <Property name="textColor">#6B88A9</Property>
          <Property name="textSize">15</Property>
        </Element>

        <!-- 底部 TabBar -->
        <Element id="TabBar_Bg" type="Native.Rectangle">
          <Property name="box">0,760,390,84</Property>
          <Property name="fillColor">#FFFFFF</Property>
          <Property name="strokeColor">#E0E8F5</Property>
          <Property name="strokeWidth">1</Property>
        </Element>
        <Element id="TabBar_T1" type="Native.Text">
          <Property name="box">35,780,40,20</Property>
          <Property name="textContent">首页</Property>
          <Property name="textColor">#1664D9</Property> <!-- 选中态 -->
          <Property name="textSize">12</Property>
        </Element>
        <Element id="TabBar_T2" type="Native.Text">
          <Property name="box">120,780,50,20</Property>
          <Property name="textContent">功能中心</Property>
          <Property name="textColor">#6B88A9</Property>
          <Property name="textSize">12</Property>
        </Element>
        <Element id="TabBar_T3" type="Native.Text">
          <Property name="box">220,780,40,20</Property>
          <Property name="textContent">收藏</Property>
          <Property name="textColor">#6B88A9</Property>
          <Property name="textSize">12</Property>
        </Element>
        <Element id="TabBar_T4" type="Native.Text">
          <Property name="box">310,780,40,20</Property>
          <Property name="textContent">我的</Property>
          <Property name="textColor">#6B88A9</Property>
          <Property name="textSize">12</Property>
        </Element>
      </Elements>
    </Page>

