12px 28px var(--c-shadow-12);\n  border-color: var(--c-brand-25);\n}\n.card-interactive:active {\n  transform: translateY(0) scale(0.99);\n}\n\n/* ===== stagger 进入动效 ===== */\n.stagger-enter > * {\n  opacity: 0;\n  transform: translateY(24px);\n  animation: revealUp 0.6s cubic-bezier(0.32,0.72,0,1) forwards;\n}\n.stagger-enter > *:nth-child(1) { animation-delay: 0.1s; }\n.stagger-enter > *:nth-child(2) { animation-delay: 0.2s; }\n.stagger-enter > *:nth-child(3) { animation-delay: 0.3s; }\n.stagger-enter > *:nth-child(4) { animation-delay: 0.4s; }\n.stagger-enter > *:nth-child(5) { animation-delay: 0.5s; }\n.stagger-enter > *:nth-child(6) { animation-delay: 0.6s; }\n.stagger-enter > *:nth-child(n+7) { animation-delay: 0.7s; }\n\n/* ===== 标题呼吸动效 (大标题用) ===== */\n@keyframes titleBreathe {\n  0%, 100% {\n    text-shadow: 0 4px 40px rgba(0,0,0,0.4);\n    transform: scale(1);\n  }\n  50% {\n    text-shadow: 0 4px 60px rgba(0,0,0,0.6), 0 0 80px rgba(58,107,140,0.3);\n    transform: scale(1.01);\n  }\n}\n@keyframes heroFadeUp {\n  from { opacity: 0; transform: translateY(28px); }\n  to { opacity: 1; transform: translateY(0); }\n}\n.title-breathe {\n  animation: heroFadeUp 0.9s cubic-bezier(0.32,0.72,0,1) 0.5s forwards,\n             titleBreathe 4s ease-in-out 1.4s infinite;\n}\n\n/* ===== 视差容器 ===== */\n.parallax-container { overflow: hidden; position: relative; }\n.parallax-bg {\n  position: absolute;\n  inset: -20%;\n  background-size: cover;\n  background-position: center;\n  will-change: transform;\n}\n\n/* ===== 隐藏滚动条 ===== */\n.no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }\n.no-scrollbar::-webkit-scrollbar { display: none; }\n\n/* ===== 响应式图片容器 ===== */\n.img-container {\n  position: relative;\n  overflow: hidden;\n  border-radius: var(--radius);\n}\n.img-container img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.6s cubic-bezier(0.32, 0.72, 0, 1);\n}\n@media (hover: hover) {\n  .img-container:hover img {\n   