/* 首页青花瓷风格样�?*/

/* 页面主要内容层级 */
.hero-section, .search-section, .menu-card, .banner-section {
  position: relative;
  z-index: 1;
}

/* Hero区青花渲染渐变背�?*/
.home-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 620rpx;
  background: linear-gradient(180deg, #E6F0FF 0%, #F4F8FF 80%, rgba(244,248,255,0) 100%);
  opacity: 1;
  z-index: 0;
}
/* 深色模式下的 Hero 背景适配 */
.page.dark .home-hero-bg {
  background: linear-gradient(180deg, rgba(22, 100, 217, 0.15) 0%, rgba(10, 24, 43, 0.3) 80%, rgba(10, 24, 43, 0) 100%);
}
/* Hero 主视觉区 */
.hero-section {
  padding: 60rpx 0 40rpx 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.hero-title {
  color: var(--color-primary-dark);
  font-size: 80rpx;
  letter-spacing: 4rpx;
  text-shadow: none;
  font-family: "STZhongsong", "SimSun", serif;
}
.hero-subtitle {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
  color: var(--color-text-secondary);
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
.hero-subtitle .line {
  width: 40rpx;
  height: 1px;
  background-color: var(--color-text-secondary);
  opacity: 0.3;
  margin: 0 16rpx;
}

/* 搜索�?*/
.search-section {
  margin-bottom: 40rpx;
}
.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  height: 104rpx;
  border-radius: var(--radius-capsule);
  padding: 0 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(22, 100, 217, 0.15);
}

.page.dark .search-box {
  background: rgba(10, 24, 43, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
}
.search-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  margin-right: 16rpx;
}
.search-input {
  flex: 1;
  height: 100%;
  color: var(--color-text-primary);
}
.search-placeholder {
  color: var(--color-text-secondary);
}
.clear-btn {
  padding: 10rpx;
  color: var(--color-text-secondary);
}
.search-suggest {
  margin-top: 16rpx;
  background: var(--color-card-bg);
  border-radius: var(--radius-card-sm);
  padding: 16rpx 0;
  box-shadow: var(--shadow-light);
}
/* 新版实时建议下拉�?*/
.suggestions-dropdown {
  position: absolute;
  top: 100%; margin-top: 12rpx;
  left: 0;
  right: 0;
  background: var(--color-card-bg); /* 使用 css 变量自适应深浅色 */
  border-radius: var(--radius-card);
  box-shadow: 0 8rpx 30rpx rgba(22, 100, 217, 0.25); /* 增强层级阴影 */
  max-height: 480rpx;
  overflow-y: auto;
  z-index: 9999; /* 保证绝对在上 */
  text-align: left;
}

.page.dark .suggestions-dropdown {
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.suggestion-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid rgba(22, 100, 217, 0.05);
}
.suggestion-item:last-child {
  border-bottom: none;
}
.suggestion-mark {
  color: var(--color-primary);
  font-size: 24rpx;
  margin-right: 8rpx;
}
.suggest-item {
  padding: 20rpx 32rpx;
  border-bottom: 1px solid var(--color-bg);
}
.suggest-item:last-child {
  border-bottom: none;
}
.suggest-empty {
  padding: 32rpx;
  text-align: center;
  color: var(--color-text-secondary);
}

/* 快捷入口4宫格 */
.menu-card {
  background: var(--color-card-bg);
  border-radius: var(--radius-card-lg);
  padding: 40rpx 20rpx;
  box-shadow: 0 12rpx 36rpx rgba(22, 100, 217, 0.08);
  border: none;
  margin-bottom: 48rpx;
}

.page.dark .menu-card {
  box-shadow: 0 12rpx 36rpx rgba(0, 0, 0, 0.4);
}
.menu-grid {
  display: flex;
  justify-content: space-around;
  align-items: flex-start;
}
.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 25%;
}
.menu-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  background: transparent;
  border-radius: 50rpx;
  border: 2rpx solid var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  color: var(--color-primary-dark);
  font-size: 44rpx;
  font-family: "STZhongsong", "SimSun", serif;
}
.menu-text {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
  color: var(--color-text-primary);
}
.menu-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

/* 精选专�?Banner */
.section-title {
  display: inline-block;
  color: var(--color-primary-dark);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.section-title-wrap {
  display: flex;
  align-items: center;
}
.section-icon {
  font-size: 40rpx;
  line-height: 48rpx;
  margin-right: 12rpx;
}
.section-more {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}
.banner-swiper {
  height: 340rpx;
  position: relative;
}
.banner-card {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-card-lg);
  overflow: hidden;
  position: relative;
  background: var(--color-primary);
  border: none;
  box-shadow: var(--shadow-card);
  transition: transform 180ms ease, box-shadow 180ms ease;
  transform: scale(1);
}

.banner-hover {
  transform: scale(0.985);
  box-shadow: 0 8rpx 16rpx rgba(18, 59, 107, 0.08); /* 轻微回落的阴影变得更浅 */
}

.page.dark .banner-hover {
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
}

/* 自定义分页器 - 东方云雾与青花胶囊 */
.custom-indicator {
  position: absolute;
  bottom: 24rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  pointer-events: none;
}

.indicator-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.35);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  width: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15); /* 微高光 */
}

.banner-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}
.banner-content {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: linear-gradient(to right, rgba(18,59,107,0.7) 0%, rgba(18,59,107,0) 100%);
  box-sizing: border-box;
}
.banner-title {
  color: #fff;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}
.banner-subtitle {
  color: #fff;
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}
.banner-desc {
  color: rgba(255,255,255,0.85);
  font-size: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 32rpx;
}
.banner-btn {
  align-self: flex-start;
  background: var(--color-card-bg);
  color: var(--color-primary-dark);
  font-size: 26rpx;
  font-weight: bold;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
}

.search-history {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #e4effc;
}

.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.history-note {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.history-chip {
  background: #f3f8ff;
  border: 1rpx solid rgba(94, 143, 206, 0.16);
  color: var(--color-primary-dark);
}

.page.dark .history-chip {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.1);
  color: var(--color-text-secondary);
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.quick-card {
  display: flex;
  flex-direction: column;
  min-height: 212rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.88) 0%, rgba(243, 248, 255, 0.92) 100%);
  border: 1rpx solid rgba(135, 181, 234, 0.42);
  box-shadow: 0 16rpx 30rpx rgba(46, 99, 175, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.page.dark .quick-card {
  background: linear-gradient(180deg, var(--color-card-bg) 0%, rgba(255, 255, 255, 0.02) 100%);
  border-color: rgba(255, 255, 255, 0.05);
  box-shadow: 0 16rpx 30rpx rgba(0,0,0, 0.2);
}

.quick-card.emphasis {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98) 0%, rgba(238, 246, 255, 0.96) 100%);
  border-color: rgba(55, 109, 183, 0.24);
  box-shadow: 0 24rpx 40rpx rgba(34, 103, 197, 0.14);
}

.page.dark .quick-card.emphasis {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 24rpx 40rpx rgba(0, 0, 0, 0.3);
}

.quick-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: rgba(39, 87, 161, 0.1);
  color: var(--color-primary);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.page.dark .quick-icon {
  background: rgba(255, 255, 255, 0.05);
  color: #5AA9FF; /* 稍亮的蓝色 */
}

.quick-title {
  margin-top: 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.quick-desc {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.7;
  color: var(--color-text-secondary);
}

.quick-card.emphasis .quick-icon {
  background: rgba(39, 87, 161, 0.12);
  color: var(--color-primary);
}

.quick-card.emphasis .quick-title,
.quick-card.emphasis .quick-desc {
  color: var(--color-primary-dark);
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-frame {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(124, 173, 224, 0.22);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 28rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(14, 39, 72, 0.04) 0%, rgba(18, 48, 86, 0.68) 100%);
}

.banner-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
}

.banner-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.9);
}

.bottom-safe {
  height: 56rpx;
}

.dark.page {
  background: linear-gradient(180deg, #071525 0%, #0b1d33 42%, #10243e 100%);
  color: #ebf4ff;
}

.dark .page-bg {
  background-image:
    radial-gradient(circle at 50% -10%, rgba(220, 235, 255, 0.08) 0%, rgba(220, 235, 255, 0.02) 18%, rgba(220, 235, 255, 0) 34%),
    radial-gradient(ellipse at 18% 16%, rgba(49, 95, 175, 0.2) 0%, rgba(49, 95, 175, 0.05) 28%, rgba(49, 95, 175, 0) 56%),
    radial-gradient(ellipse at 84% 22%, rgba(87, 140, 199, 0.18) 0%, rgba(87, 140, 199, 0.04) 30%, rgba(87, 140, 199, 0) 58%),
    linear-gradient(180deg, rgba(18, 51, 98, 0.18) 0%, rgba(18, 51, 98, 0.06) 44%, rgba(18, 51, 98, 0.16) 100%);
}

.dark .bg-grid {
  background-image:
    linear-gradient(180deg, rgba(120, 170, 233, 0.12) 0%, rgba(120, 170, 233, 0.03) 78%, rgba(120, 170, 233, 0) 100%),
    repeating-linear-gradient(90deg, rgba(143, 188, 244, 0.14) 0, rgba(143, 188, 244, 0.14) 2rpx, transparent 2rpx, transparent 26rpx),
    repeating-radial-gradient(circle at 0 100%, rgba(116, 164, 229, 0.2) 0 12rpx, rgba(116, 164, 229, 0) 12rpx 30rpx),
    repeating-radial-gradient(circle at 28rpx 100%, rgba(53, 99, 171, 0.18) 0 9rpx, rgba(53, 99, 171, 0) 9rpx 24rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 22%);
  opacity: 0.44;
}

.dark .hero-card {
  background: linear-gradient(145deg, rgba(12, 28, 49, 0.96) 0%, rgba(15, 36, 63, 0.94) 100%);
  border-color: rgba(88, 127, 181, 0.28);
  box-shadow: 0 26rpx 52rpx rgba(0, 0, 0, 0.28);
}

.dark .hero-card::before {
  background:
    radial-gradient(circle at 78% 24%, rgba(80, 132, 205, 0.16) 0%, rgba(80, 132, 205, 0.04) 22%, rgba(80, 132, 205, 0) 44%),
    linear-gradient(125deg, rgba(49, 95, 176, 0.1) 0%, rgba(49, 95, 176, 0) 26%, rgba(111, 172, 219, 0.1) 52%, rgba(111, 172, 219, 0) 78%);
}

.dark .hero-card::after {
  border-color: rgba(122, 180, 255, 0.12);
}

.dark .hero-title,
.dark .panel-title,
.dark .history-title {
  color: #edf5ff;
}

.dark .hero-tag,
.dark .hero-subtitle,
.dark .panel-note,
.dark .suggest-empty,
.dark .history-note,
.dark .quick-desc {
  color: #9fb8d8;
}

.dark .hero-badge,
.dark .suggest-item,
.dark .history-chip {
  border-color: rgba(122, 180, 255, 0.12);
  color: #dceeff;
}

.dark .hero-badge {
  background: rgba(71, 112, 165, 0.18);
}

.dark .panel,
.dark .quick-card {
  background: rgba(10, 24, 43, 0.9);
  border-color: rgba(96, 139, 191, 0.28);
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.24);
}

.dark .quick-card.emphasis {
  background: rgba(12, 28, 49, 0.94);
}

.dark .quick-title,
.dark .search-input {
  color: #edf5ff;
}

.dark .search-box {
  background: rgba(16, 35, 63, 0.9);
  border-color: rgba(96, 139, 191, 0.24);
}

.dark .search-icon,
.dark .search-btn {
  background: linear-gradient(145deg, #214980 0%, #356ca8 56%, #6a9fd1 100%);
}
