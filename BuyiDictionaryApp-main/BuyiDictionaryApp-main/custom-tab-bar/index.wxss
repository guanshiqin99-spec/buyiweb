.custom-tabbar {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: calc(30rpx + env(safe-area-inset-bottom));
  height: 110rpx;
  z-index: 999;
  border-radius: 60rpx;
  /* 云雾悬浮 TabBar */
  background: rgba(255, 255, 255, 0.32);
  backdrop-filter: blur(32rpx) saturate(140%);
  -webkit-backdrop-filter: blur(32rpx) saturate(140%);
  box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.45), 0 16rpx 40rpx rgba(22, 100, 217, 0.12);
  border: 1rpx solid rgba(120, 160, 210, 0.18);
}

.custom-tabbar.dark {
  background: rgba(10, 24, 43, 0.42); /* 统一沉静的深墨蓝磨砂底 */
  backdrop-filter: blur(32rpx) saturate(140%);
  -webkit-backdrop-filter: blur(32rpx) saturate(140%);
  box-shadow: inset 0 1px 0.5px rgba(255, 255, 255, 0.06), 0 16rpx 40rpx rgba(0, 0, 0, 0.55);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.tabbar-list {
  position: relative;
  height: 100%;
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.tabbar-item {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tabbar-icon {
  width: 46rpx;
  height: 46rpx;
  margin-bottom: 6rpx;
}

.tabbar-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tabbar-text.active {
  color: #1664D9;
  font-weight: 600;
  text-shadow: 0 4rpx 12rpx rgba(22, 100, 217, 0.3);
}

.custom-tabbar.dark .tabbar-text {
  color: rgba(255, 255, 255, 0.6);
}

.custom-tabbar.dark .tabbar-text.active {
  color: #5AA9FF;
  text-shadow: 0 4rpx 12rpx rgba(90, 169, 255, 0.4);
}
