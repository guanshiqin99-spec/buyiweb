<view class="page {{currentTheme}} {{fontSizeClass}} login-page">
  <custom-nav title=""></custom-nav>

  <!-- 水墨背景层 -->
  <view class="page-bg">
    <view class="ink-wash-top"></view>
    <view class="ink-wash-left-branch"></view>
    <view class="ink-wash-right-mountain"></view>
    <view class="ink-wash-mid-cloud"></view>
    <view class="ink-wash-bottom-wave"></view>
  </view>

  <view class="login-container">

    <!-- 品牌悬浮区 -->
    <view class="brand fade-in-up">
      <view class="brand-badge">
        <image class="brand-badge-image" src="/assets/icons/app(2).jpg" mode="aspectFit" />
      </view>
      <text class="logo">布依声典</text>
      <view class="logo-divider">
        <view class="divider-line"></view>
        <text class="logo-sub">传承布依语言与文化</text>
        <view class="divider-line"></view>
      </view>
    </view>

    <!-- 文化 Slogan -->
    <view class="cultural-slogan fade-in-up" style="animation-delay:120ms;">
      听见布依 · 看见文化
    </view>

    <view class="spacer"></view>

    <!-- 登录区 -->
    <view class="login-card fade-in-up" style="animation-delay:200ms;">
      <view class="login-card-inner">
        <!-- 功能说明小图标行 -->
        <view class="feature-row">
          <view class="feature-item">
            <view class="feature-icon">☆</view>
            <text class="feature-label">同步收藏</text>
          </view>
          <view class="feature-item">
            <view class="feature-icon">册</view>
            <text class="feature-label">学习记录</text>
          </view>
          <view class="feature-item">
            <view class="feature-icon">◎</view>
            <text class="feature-label">个性设置</text>
          </view>
        </view>

        <button class="btn glazed-btn main-btn" bindtap="showProfileModal" disabled="{{loading}}">
          微信授权登录
        </button>

        <view class="guest-mode">
          <text class="guest-link" bindtap="cancel">暂不登录</text>
        </view>
      </view>
    </view>

    <view class="bottom-note fade-in-up" style="animation-delay:320ms;">
      <text>登录后可同步收藏与学习记录</text>
    </view>

  </view>

  <!-- 资料填写弹窗 -->
  <view class="profile-modal" wx:if="{{showModal}}">
    <view class="profile-modal-mask" bindtap="hideProfileModal"></view>
    <view class="profile-modal-content">
      <view class="profile-modal-header">完善个人资料</view>
      
      <view class="profile-input-group">
        <button class="avatar-choose-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="avatar-image" src="{{avatarUrl}}" mode="aspectFill"></image>
          <view class="avatar-edit-mask">
            <text class="avatar-edit-text">获取</text>
          </view>
        </button>
        
        <view class="nickname-input-box">
          <text class="nickname-label">昵称</text>
          <input type="nickname" class="nickname-input" placeholder="点击获取微信昵称" bindinput="onInputChange" bindblur="onInputChange" bindchange="onInputChange" value="{{nickname}}" />
        </view>
      </view>

      <view class="profile-modal-actions">
        <button class="btn profile-cancel-btn" bindtap="hideProfileModal">取消</button>
        <button class="btn profile-confirm-btn main-btn glazed-btn" bindtap="doLogin" disabled="{{loading}}">
          {{loading ? '登录中...' : '确认登录'}}
        </button>
      </view>
    </view>
  </view>
</view>
