.page {
  position: relative;
  min-height: 100vh;
  /* 采用首页的“白-青蓝”水墨渐变背景 */
  background: var(--color-bg);
  color: var(--color-text-primary);
}

.home-hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 620rpx;
  background: linear-gradient(180deg, #E6F0FF 0%, #F4F8FF 80%, rgba(244,248,255,0) 100%);
  opacity: 1;
  z-index: 0;
}

.page.dark .home-hero-bg {
  background: linear-gradient(180deg, rgba(22, 100, 217, 0.15) 0%, rgba(10, 24, 43, 0.3) 80%, rgba(10, 24, 43, 0) 100%);
}

.bg-cloud {
  position: absolute;
  top: 0;
  right: 0;
  width: 100%;
  height: 100%;
  background-image: 
    radial-gradient(ellipse at 85% 95%, rgba(22, 100, 217, 0.15) 0%, rgba(22, 100, 217, 0) 40%),
    radial-gradient(ellipse at 15% 100%, rgba(87, 140, 199, 0.18) 0%, rgba(87, 140, 199, 0) 45%),
    radial-gradient(circle at 90% 10%, rgba(35, 85, 167, 0.05) 0%, rgba(35, 85, 167, 0) 40%),
    radial-gradient(circle at 10% 20%, rgba(35, 85, 167, 0.03) 0%, rgba(35, 85, 167, 0) 30%);
  opacity: 0.9;
  z-index: 0;
}

.page.dark .bg-cloud {
  background-image: 
    radial-gradient(ellipse at 85% 95%, rgba(22, 100, 217, 0.08) 0%, rgba(22, 100, 217, 0) 40%),
    radial-gradient(ellipse at 15% 100%, rgba(87, 140, 199, 0.1) 0%, rgba(87, 140, 199, 0) 45%);
}

.page-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.app-scroll {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  padding: 0rpx 28rpx 0;
}

.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 34rpx;
  padding: 20rpx 0;
}

.hero-kicker,
.hero-title,
.hero-desc {
  position: relative;
}

.hero-kicker {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: var(--color-text-secondary);
}

.hero-title {
  font-size: 60rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  font-family: "STZhongsong", "SimSun", serif;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
}

.hero-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28rpx;
}

.feature-card {
  display: flex;
  flex-direction: column;
  min-height: 280rpx;
  padding: 32rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(243, 248, 255, 0.96) 100%);
  border: 1rpx solid rgba(135, 181, 234, 0.3);
  box-shadow: 0 20rpx 40rpx rgba(45, 100, 176, 0.08);
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.page.dark .feature-card {
  background: linear-gradient(180deg, rgba(14, 30, 52, 0.98) 0%, rgba(10, 24, 43, 0.96) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.4);
}

.feature-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 100% 100%, rgba(22, 100, 217, 0.03) 0%, transparent 60%);
  z-index: 0;
  pointer-events: none;
}

.page.dark .feature-card::before {
  background-image: radial-gradient(circle at 100% 100%, rgba(22, 100, 217, 0.1) 0%, transparent 60%);
}

.feature-card.primary {
  background: linear-gradient(145deg, rgba(255, 255, 255, 0.98) 0%, rgba(238, 246, 255, 0.96) 100%);
  border-color: rgba(55, 109, 183, 0.24);
  box-shadow: 0 24rpx 44rpx rgba(34, 101, 194, 0.14);
}

.page.dark .feature-card.primary {
  background: linear-gradient(145deg, rgba(20, 40, 70, 0.98) 0%, rgba(14, 30, 52, 0.96) 100%);
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 24rpx 44rpx rgba(0, 0, 0, 0.5);
}

.feature-card.accent {
  background: linear-gradient(180deg, #fbfdff 0%, #eef5ff 100%);
}

.page.dark .feature-card.accent {
  background: linear-gradient(180deg, rgba(14, 30, 52, 0.95) 0%, rgba(10, 24, 43, 0.95) 100%);
}

.feature-top, .feature-title, .feature-desc {
  position: relative;
  z-index: 1;
}

.feature-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.feature-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50rpx;
  background: transparent;
  border: 2rpx dashed var(--color-primary-light);
  color: var(--color-primary-dark);
  font-size: 44rpx;
  font-family: "STZhongsong", "SimSun", serif;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.feature-icon::after {
  content: '';
  position: absolute;
  top: -6rpx; left: -6rpx; right: -6rpx; bottom: -6rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(22, 100, 217, 0.15);
}

.feature-arrow {
  font-size: 34rpx;
  color: var(--color-text-secondary);
}

.feature-title {
  font-size: 31rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.feature-desc {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
}

.feature-card.primary .feature-icon {
  border-color: rgba(22, 100, 217, 0.4);
  color: var(--color-primary-dark);
}

.feature-card.primary .feature-arrow,
.feature-card.primary .feature-title,
.feature-card.primary .feature-desc {
  color: #1c4e88;
}

.page.dark .feature-card.primary .feature-arrow,
.page.dark .feature-card.primary .feature-title {
  color: #EDF5FF;
}

.page.dark .feature-card.primary .feature-desc {
  color: #9FB8D8;
}

.guide-panel {
  margin-top: 30rpx;
  padding: 40rpx 32rpx;
  border-radius: 30rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(244, 249, 255, 0.95) 100%);
  border: 1rpx solid rgba(167, 207, 255, 0.3);
  box-shadow: 0 16rpx 32rpx rgba(45, 100, 176, 0.05);
  position: relative;
  overflow: hidden;
}

.page.dark .guide-panel {
  background: linear-gradient(180deg, rgba(14, 30, 52, 0.98) 0%, rgba(10, 24, 43, 0.95) 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.4);
}

.guide-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: 
    linear-gradient(90deg, rgba(22, 100, 217, 0.02) 1px, transparent 1px),
    linear-gradient(rgba(22, 100, 217, 0.02) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  pointer-events: none;
}

.guide-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-primary-dark);
  font-family: "STZhongsong", "SimSun", serif;
  position: relative;
  z-index: 1;
}

.guide-title::before {
  content: '☁';
  margin-right: 12rpx;
  color: var(--color-primary-light);
  font-size: 28rpx;
}

.guide-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 28rpx;
  position: relative;
  z-index: 1;
}

.guide-item {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
  padding-bottom: 24rpx;
  border-bottom: 1rpx dashed rgba(22, 100, 217, 0.1);
}

.page.dark .guide-item {
  border-bottom: 1rpx dashed rgba(255, 255, 255, 0.1);
}

.guide-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.guide-index {
  min-width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: transparent;
  border: 2rpx solid var(--color-primary-dark);
  color: var(--color-primary-dark);
  font-size: 24rpx;
  font-weight: bold;
  font-family: "STZhongsong", "SimSun", serif;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.page.dark .guide-index {
  border-color: #EDF5FF;
  color: #EDF5FF;
}

.guide-index::after {
  content: '';
  position: absolute;
  top: 4rpx; left: 4rpx; right: 4rpx; bottom: 4rpx;
  border-radius: 50%;
  border: 2rpx dashed rgba(18, 59, 107, 0.3);
}

.page.dark .guide-index::after {
  border: 2rpx dashed rgba(255, 255, 255, 0.3);
}

.guide-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--color-text-secondary);
  padding-top: 6rpx;
}

.bottom-safe {
  height: 180rpx;
}

.dark.page {
  background: linear-gradient(180deg, #071525 0%, #0b1d33 42%, #10243e 100%);
  color: #eaf3ff;
}

.dark .page-bg {
  background-image:
    radial-gradient(circle at 50% -10%, rgba(220, 235, 255, 0.08) 0%, rgba(220, 235, 255, 0.02) 18%, rgba(220, 235, 255, 0) 34%),
    radial-gradient(ellipse at 18% 16%, rgba(49, 95, 175, 0.2) 0%, rgba(49, 95, 175, 0.05) 28%, rgba(49, 95, 175, 0) 56%),
    radial-gradient(ellipse at 84% 22%, rgba(87, 140, 199, 0.18) 0%, rgba(87, 140, 199, 0.04) 30%, rgba(87, 140, 199, 0) 58%),
    linear-gradient(180deg, rgba(18, 51, 98, 0.18) 0%, rgba(18, 51, 98, 0.06) 44%, rgba(18, 51, 98, 0.16) 100%);
}

.dark .bg-grid {
  background-image:
    linear-gradient(180deg, rgba(120, 170, 233, 0.12) 0%, rgba(120, 170, 233, 0.03) 78%, rgba(120, 170, 233, 0) 100%),
    repeating-linear-gradient(90deg, rgba(143, 188, 244, 0.14) 0, rgba(143, 188, 244, 0.14) 2rpx, transparent 2rpx, transparent 26rpx),
    repeating-radial-gradient(circle at 0 100%, rgba(116, 164, 229, 0.2) 0 12rpx, rgba(116, 164, 229, 0) 12rpx 30rpx),
    repeating-radial-gradient(circle at 28rpx 100%, rgba(53, 99, 171, 0.18) 0 9rpx, rgba(53, 99, 171, 0) 9rpx 24rpx),
    linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 22%);
  opacity: 0.44;
}

.dark .hero {
  background: linear-gradient(145deg, rgba(12, 28, 49, 0.96) 0%, rgba(15, 36, 63, 0.94) 100%);
  border-color: rgba(88, 127, 181, 0.28);
}

.dark .hero::before {
  background:
    radial-gradient(circle at 82% 22%, rgba(80, 132, 205, 0.16) 0%, rgba(80, 132, 205, 0.04) 22%, rgba(80, 132, 205, 0) 44%),
    linear-gradient(125deg, rgba(49, 95, 176, 0.1) 0%, rgba(49, 95, 176, 0) 26%, rgba(111, 172, 219, 0.1) 52%, rgba(111, 172, 219, 0) 78%);
}

.dark .hero-kicker,
.dark .hero-desc,
.dark .guide-text,
.dark .feature-desc {
  color: #9fb8d8;
}

.dark .hero-title,
.dark .guide-title,
.dark .feature-title {
  color: #edf5ff;
}

.dark .feature-card,
.dark .guide-panel {
  background: rgba(10, 24, 43, 0.9);
  border-color: rgba(96, 139, 191, 0.28);
  box-shadow: 0 18rpx 34rpx rgba(0, 0, 0, 0.24);
}

.dark .feature-card.primary {
  background: rgba(12, 28, 49, 0.94);
}

.dark .feature-icon,
.dark .guide-index {
  background: rgba(118, 184, 255, 0.16);
  color: #dceeff;
}
