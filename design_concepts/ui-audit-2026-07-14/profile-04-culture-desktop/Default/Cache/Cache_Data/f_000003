adient(180deg,\n      rgba(255, 255, 255, 0.18) 0%,\n      rgba(255, 255, 255, 0.05) 14%,\n      rgba(255, 255, 255, 0.01) 32%,\n      transparent 60%),\n    radial-gradient(140% 90% at 50% 122%,\n      rgba(58, 107, 140, 0.07) 0%,\n      rgba(212, 136, 58, 0.03) 38%,\n      transparent 62%),\n    linear-gradient(180deg,\n      rgba(var(--lg-tint), var(--lg-tint-a)) 0%,\n      rgba(var(--lg-tint), calc(var(--lg-tint-a) * 0.82)) 100%);\n  /* 菲涅尔边缘反射 + 物理厚度内阴影 + 边缘光响应光标 + 柔和物理投影 */\n  box-shadow:\n    inset 0 1px 1px rgba(255, 255, 255, 0.48),          /* 顶部内高光 (厚度) */\n    inset 0 -1px 1px var(--c-text-10),                  /* 底部内阴影 (厚度) */\n    inset 0 0 0 1px rgba(255, 255, 255, 0.06),          /* 内圈微反光 */\n    inset calc(var(--lg-edge-x, 0) * 1px) 0 8px rgba(255, 255, 255, 0.10), /* 边缘光响应光标 */\n    var(--shadow-xs),                                    /* 接触阴影 */\n    var(--shadow-sm),                                    /* 近投影 */\n    var(--shadow-md);                                    /* 中投影 */\n  transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1),\n              --lg-spec 300ms ease;\n}\n\n/* Hero 玻璃：更厚、更亮、更有景深，用于搜索弹窗、播放器、登录卡 */\n.liquid-glass-hero {\n  --lg-spec: 0.34;\n  --lg-tint-a: 0.65;\n  background:\n    linear-gradient(180deg,\n      rgba(255, 255, 255, 0.28) 0%,\n      rgba(255, 255, 255, 0.08) 14%,\n      rgba(255, 255, 255, 0.02) 32%,\n      transparent 60%),\n    radial-gradient(140% 90% at 50% 122%,\n      rgba(58, 107, 140, 0.10) 0%,\n      rgba(212, 136, 58, 0.04) 38%,\n      transparent 62%),\n    linear-gradient(180deg,\n      rgba(var(--lg-tint), var(--lg-tint-a)) 0%,\n      rgba(var(--lg-tint), calc(var(--lg-tint-a) * 0.82)) 100%);\n  box-shadow:\n    inset 0 1px 1px rgba(255, 255, 255, 0.62),\n    inset 0 -1px 1px var(--c-text-10),\n    inset 0 0 0 1px rgba(255, 255, 255, 0.10),\n    inset calc(var(--lg-edge-x, 0) * 1px) 0 10px rgba(255, 255, 255, 0.16),\n    var(--shadow-sm),\n    var(--shadow-md),\n    var(--shadow-lg);\n}\n\n/* Quie