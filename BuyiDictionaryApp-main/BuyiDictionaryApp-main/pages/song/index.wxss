/* 山水唱片馆 - 民歌页样式 */

.song-page {
  position: relative;
}

/* 山水理背景 */
.song-bg-texture {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 500rpx;
  background: 
    radial-gradient(circle at 100% 0%, rgba(135, 185, 230, 0.08) 0%, transparent 40%),
    radial-gradient(circle at 0% 10%, rgba(90, 169, 255, 0.06) 0%, transparent 50%);
  z-index: -1;
}

.page.dark .song-bg-texture {
  background: 
    radial-gradient(circle at 100% 0%, rgba(81, 126, 178, 0.05) 0%, transparent 40%),
    radial-gradient(circle at 0% 10%, rgba(35, 66, 102, 0.08) 0%, transparent 50%);
}

.header-section {
  margin-bottom: 40rpx;
}

.title-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.song-main-title {
  font-weight: 600; /* 去掉极度粗黑 */
  color: var(--color-primary-dark);
}

.page.dark .song-main-title {
  color: #EDF5FF;
}

.title-cloud {
  color: rgba(94, 143, 206, 0.4);
  font-size: 40rpx;
  margin-left: 16rpx;
}

.song-sub-title {
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

/* 推荐大卡 (山水唱片款) */
.hero-record-card {
  position: relative;
  height: 480rpx;
  border-radius: 36rpx;
  margin-bottom: 56rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 40rpx rgba(34, 103, 197, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

.page.dark .hero-record-card {
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.4);
  border-color: rgba(255, 255, 255, 0.08);
}

.hero-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-glass-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 40rpx;
  background: linear-gradient(180deg, rgba(15, 40, 90, 0.12), rgba(15, 40, 90, 0.38));
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.hero-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.hero-tags {
  display: inline-flex;
  align-items: center;
  margin-bottom: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(8rpx);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(255,255,255,0.2);
}

.hero-tag-icon {
  font-size: 18rpx;
  color: #fff;
  margin-right: 6rpx;
}

.hero-tag-text {
  font-size: 20rpx;
  color: #ffffff;
}

.hero-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

/* 玉石唱针按钮 */
.jade-play-btn {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12rpx);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 2rpx 2rpx rgba(255, 255, 255, 1), 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  flex-shrink: 0;
  margin-left: 24rpx;
}

.page.dark .jade-play-btn {
  background: rgba(10, 24, 43, 0.6);
  border-color: rgba(255, 255, 255, 0.15);
  box-shadow: inset 0 2rpx 2rpx rgba(255, 255, 255, 0.1), 0 8rpx 24rpx rgba(0, 0, 0, 0.5);
}

.jade-play-icon {
  color: #16467A;
  font-size: 40rpx;
  margin-left: 8rpx; /* 修正三角重心居中 */
}

.page.dark .jade-play-icon {
  color: #EDF5FF;
}

/* Banner指示点 */
.hero-dots {
  position: absolute;
  bottom: 12rpx;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.4);
  border-radius: 4rpx;
}

.dot.active {
  width: 24rpx;
  background: #fff;
}

/* 共享标题样式 */
.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 24rpx;
  color: rgba(94, 143, 206, 0.6);
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.section-more {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 列表区 */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.song-record-list {
  padding-bottom: 40rpx;
}

.record-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(to right, rgba(255,255,255,0.9), rgba(255,255,255,0.6));
  border-radius: 28rpx;
  border: 1rpx solid rgba(22, 100, 217, 0.08);
  box-shadow: 0 4rpx 16rpx rgba(22, 100, 217, 0.03);
}

.page.dark .record-card {
  background: linear-gradient(to right, var(--color-card-bg), rgba(255,255,255,0.02));
  border-color: rgba(255, 255, 255, 0.05);
}

.record-cover-wrap {
  width: 140rpx;
  height: 100rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  overflow: hidden;
  border: 2rpx solid rgba(120, 160, 210, 0.18);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  flex-shrink: 0;
}

.record-cover {
  width: 100%;
  height: 100%;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.record-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.record-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-right: 12rpx;
}

.record-tag {
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(22, 100, 217, 0.2);
  color: var(--color-primary-dark);
}

.page.dark .record-tag {
  border-color: rgba(255,255,255,0.2);
  color: #9FB8D8;
}

.record-artist {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.play-count, .duration {
  font-size: 20rpx;
  color: rgba(22, 100, 217, 0.4);
}

.page.dark .play-count, .page.dark .duration {
  color: rgba(255, 255, 255, 0.3);
}

/* 青花/玉佩印章感收藏 */
.seal-fav-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 20rpx;
}

.seal-fav-icon {
  font-size: 32rpx;
  color: rgba(94, 143, 206, 0.4);
  transition: all 0.3s ease;
}

.seal-fav-btn.active .seal-fav-icon {
  color: #1664D9;
  text-shadow: 0 0 12rpx rgba(22, 100, 217, 0.4);
}

.page.dark .seal-fav-btn.active .seal-fav-icon {
  color: #5AA9FF;
}

/* 状态卡片 */
.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
  border-style: dashed;
}

.status-card .text-h3 {
  margin-bottom: 16rpx;
}

.status-card.error {
  border-color: var(--color-error);
  background: var(--color-danger-bg);
}

.text-danger {
  color: var(--color-error);
}