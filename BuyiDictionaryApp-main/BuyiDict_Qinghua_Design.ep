          <Property name="textColor">#173B6C</Property>
          <Property name="textSize">12</Property>
          <Property name="textAlign">center</Property>
        </Element>
        <!-- 快捷入口2：常用语 -->
        <Element id="Home_Menu2_Icon" type="Native.Rectangle">
          <Property name="box">120,240,48,48</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="radius">24</Property>
        </Element>
        <Element id="Home_Menu2_Text" type="Native.Text">
          <Property name="box">115,296,58,20</Property>
          <Property name="textContent">常用语</Property>
          <Property name="textColor">#173B6C</Property>
          <Property name="textSize">12</Property>
          <Property name="textAlign">center</Property>
        </Element>
        <!-- 快捷入口3：谚语 -->
        <Element id="Home_Menu3_Icon" type="Native.Rectangle">
          <Property name="box">200,240,48,48</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="radius">24</Property>
        </Element>
        <Element id="Home_Menu3_Text" type="Native.Text">
          <Property name="box">195,296,58,20</Property>
          <Property name="textContent">谚语</Property>
          <Property name="textColor">#173B6C</Property>
          <Property name="textSize">12</Property>
          <Property name="textAlign">center</Property>
        </Element>
        <!-- 快捷入口4：民歌欣赏 -->
        <Element id="Home_Menu4_Icon" type="Native.Rectangle">
          <Property name="box">280,240,48,48</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="radius">24</Property>
        </Element>
        <Element id="Home_Menu4_Text" type="Native.Text">
          <Property name="box">275,296,58,20</Property>
