<?xml version="1.0" encoding="UTF-8"?>
<Document xmlns="http://www.evolus.vn/Namespace/Pencil" xmlns:p="http://www.evolus.vn/Namespace/Pencil" id="QinghuaDictApp" version="3.1.0">
  <Properties>
    <Property name="title">布依语词典微信小程序 - 青花瓷釉彩设计</Property>
    <Property name="description">现代、清爽、学习型、有文化感的移动端小程序设计</Property>
    <Property name="author">AI UI/UX Pro Max</Property>
    <Property name="width">390</Property>
    <Property name="height">844</Property>
  </Properties>

  <!-- 颜色与主题板 -->
  <Pages>
    <!-- 0. 组件区与规范板 -->
    <Page id="Page_Components" name="组件区与规范板">
      <Properties>
        <Property name="width">1200</Property>
        <Property name="height">1000</Property>
      </Properties>
      <Elements>
        <!-- 色彩规范卡片 -->
        <Element id="ColorPalette" type="Native.Rectangle">
          <Property name="box">100,50,300,400</Property>
          <Property name="fillColor">#FFFFFF</Property>
          <Property name="strokeColor">#123B6B</Property>
          <Property name="strokeWidth">1</Property>
          <Property name="strokeStyle">solid</Property>
          <Property name="radius">24</Property>
        </Element>
        <Element id="ColorText" type="Native.Text">
          <Property name="box">120,70,260,30</Property>
          <Property name="textContent">色彩规范 (青花瓷色系)</Property>
          <Property name="textColor">#173B6C</Property>
          <Property name="fontFamily">Arial, sans-serif</Property>
          <Property name="textSize">20</Property>
          <Property name="fontWeight">bold</Property>
        </Element>
        <!-- 主蓝：#1664D9 -->
        <Element id="Color1" type="Native.Rectangle">
          <Property name="box">120,120,60,60</Property>
          <Property name="fillColor">#1664D9</Property>
          <Property name="radius">8</Property>
        </Element>
        <Element id="Color1T" type="Native.Text">
          <Property name="box">190,140,150,20</Property>
          <Property name="textContent">主蓝: #1664D9</Property>
          <Property name="textColor">#173B6C</Property>
        </Element>
        <!-- 亮蓝：#5AA9FF -->
        <Element id="Color2" type="Native.Rectangle">
          <Property name="box">120,200,60,60</Property>
          <Property name="fillColor">#5AA9FF</Property>
          <Property name="radius">8</Property>
        </Element>
        <Element id="Color2T" type="Native.Text">
          <Property name="box">190,220,150,20</Property>
          <Property name="textContent">亮蓝 (釉彩光泽): #5AA9FF</Property>
          <Property name="textColor">#173B6C</Property>
        </Element>
        <!-- 深蓝：#123B6B -->
        <Element id="Color3" type="Native.Rectangle">
          <Property name="box">120,280,60,60</Property>
          <Property name="fillColor">#123B6B</Property>
          <Property name="radius">8</Property>
        </Element>
        <Element id="Color3T" type="Native.Text">
          <Property name="box">190,300,150,20</Property>
          <Property name="textContent">深蓝 (青花勾线): #123B6B</Property>
          <Property name="textColor">#173B6C</Property>
        </Element>
        <!-- 背景色 -->
        <Element id="Color4" type="Native.Rectangle">
          <Property name="box">120,360,60,60</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="strokeColor">#E0E8F5</Property>
          <Property name="strokeWidth">1</Property>
          <Property name="radius">8</Property>
        </Element>
        <Element id="Color4T" type="Native.Text">
          <Property name="box">190,380,150,20</Property>
          <Property name="textContent">背景瓷白: #F4F8FF</Property>
          <Property name="textColor">#173B6C</Property>
        </Element>

        <!-- 按钮组件 -->
        <Element id="Btn_Primary" type="Native.Rectangle">
          <Property name="box">500,100,200,50</Property>
          <Property name="fillColor">#1664D9</Property>
          <Property name="radius">999</Property>
        </Element>
        <Element id="Btn_Primary_Text" type="Native.Text">
          <Property name="box">500,115,200,20</Property>
          <Property name="textContent">主按钮 (蓝底白字)</Property>
          <Property name="textColor">#FFFFFF</Property>
          <Property name="textAlign">center</Property>
        </Element>

        <Element id="Btn_Secondary" type="Native.Rectangle">
          <Property name="box">500,180,200,50</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="strokeColor">#1664D9</Property>
          <Property name="strokeWidth">1</Property>
          <Property name="radius">999</Property>
        </Element>
        <Element id="Btn_Secondary_Text" type="Native.Text">
          <Property name="box">500,195,200,20</Property>
          <Property name="textContent">次按钮 / 幽灵按钮</Property>
          <Property name="textColor">#1664D9</Property>
          <Property name="textAlign">center</Property>
        </Element>
      </Elements>
    </Page>

    <!-- 1. 首页 -->
    <Page id="Page_Home" name="首页">
      <Properties>
        <Property name="width">390</Property>
        <Property name="height">844</Property>
      </Properties>
      <Elements>
        <!-- 页面背景 (青花瓷釉白底色) -->
        <Element id="Home_Bg" type="Native.Rectangle">
          <Property name="box">0,0,390,844</Property>
          <Property name="fillColor">#F4F8FF</Property>
        </Element>
        <!-- Hero 主视觉渐变底 (表现青花渲染效果) -->
        <Element id="Home_HeroBg" type="Native.Rectangle">
          <Property name="box">0,0,390,260</Property>
          <Property name="fillColor">#5AA9FF</Property>
          <Property name="strokeWidth">0</Property>
          <!-- 伪渐变效果以蓝色色块替代 -->
          <Property name="opacity">0.8</Property>
        </Element>
        <!-- 页面主标题 -->
        <Element id="Home_Title" type="Native.Text">
          <Property name="box">24,60,342,40</Property>
          <Property name="textContent">布依语辞典</Property>
          <Property name="textColor">#FFFFFF</Property>
          <Property name="textSize">34</Property>
          <Property name="fontWeight">bold</Property>
        </Element>
        <!-- 搜索框 -->
        <Element id="Home_SearchBar" type="Native.Rectangle">
          <Property name="box">24,120,342,52</Property>
          <Property name="fillColor">#FFFFFF</Property>
          <Property name="opacity">0.92</Property>
          <Property name="radius">999</Property>
          <Property name="strokeWidth">0</Property>
          <Property name="dropShadow">true</Property>
        </Element>
        <Element id="Home_SearchText" type="Native.Text">
          <Property name="box">54,136,200,20</Property>
          <Property name="textContent">搜查布依语词汇、短句...</Property>
          <Property name="textColor">#6B88A9</Property>
          <Property name="textSize">15</Property>
        </Element>
        
        <!-- 快捷入口 4 宫格背景卡 -->
        <Element id="Home_MenuCard" type="Native.Rectangle">
          <Property name="box">20,220,350,120</Property>
          <Property name="fillColor">#FFFFFF</Property>
          <Property name="opacity">0.95</Property>
          <Property name="radius">24</Property>
          <Property name="strokeColor">#1664D9</Property>
          <Property name="strokeWidth">0.5</Property> <!-- 青花极细描边 -->
          <Property name="dropShadow">true</Property>
        </Element>
        
        <!-- 快捷入口1：词典查询 -->
        <Element id="Home_Menu1_Icon" type="Native.Rectangle">
          <Property name="box">40,240,48,48</Property>
          <Property name="fillColor">#F4F8FF</Property>
          <Property name="radius">24</Property>
        </Element>
        <Element id="Home_Menu1_Text" type="Native.Text">
          <Property name="box">35,296,58,20</Property>
