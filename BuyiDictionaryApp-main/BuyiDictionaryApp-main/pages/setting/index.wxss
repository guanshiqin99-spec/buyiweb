/* 设置页青花瓷风格与东方留白设计 */

.landscape-bg {
  background: 
    url('https://my-buyi-dict.com/images/bg-mountain-top.png') no-repeat top center / 100% auto,
    url('https://my-buyi-dict.com/images/bg-wave-bottom.png') no-repeat bottom center / 100% auto,
    var(--color-bg);
}

.cultural-header {
  margin-bottom: 64rpx;
  display: flex;
  flex-direction: column;
  padding: 0 12rpx;
}

.text-title {
  font-size: 64rpx;
  font-weight: 300;
  color: #173B6C;
  margin-bottom: 8rpx;
  font-family: "KaiTi", "楷体", serif;
  letter-spacing: 4rpx;
}

.text-subtitle {
  font-size: 26rpx;
  color: rgba(23, 59, 108, 0.6);
  letter-spacing: 2rpx;
}

.setting-group {
  margin-bottom: 48rpx;
}

.group-title {
  display: block;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  font-size: 24rpx;
  color: rgba(23, 59, 108, 0.72);
  letter-spacing: 2rpx;
}

/* 白瓷浮层卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(120, 160, 210, 0.08);
  border-radius: 32rpx;
  padding: 16rpx 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(22, 100, 217, 0.04);
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
}

.arrow-item text.arrow {
  color: rgba(23, 59, 108, 0.3);
  font-size: 28rpx;
  font-weight: 300;
}

.col-item {
  flex-direction: column;
  align-items: stretch;
}

.item-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.divider {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(22,100,217,0), rgba(22,100,217,0.06), rgba(22,100,217,0));
}

/* 青瓷胶囊切换 */
.capsule-group {
  display: flex;
  background: rgba(120, 150, 200, 0.08);
  border-radius: var(--radius-capsule);
  padding: 6rpx;
  width: 320rpx;
}
.capsule-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: var(--radius-capsule);
  font-size: 26rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}
.capsule-btn.active {
  background: linear-gradient(135deg, #EEF4FF, rgba(244, 248, 255, 0.96));
  color: #1664D9;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(22,100,217,0.1);
}

/* Slider */
.slider-wrapper {
  width: 360rpx;
}
.slider-labels {
  display: flex;
  justify-content: space-between;
  padding: 0 16rpx;
  margin-top: -12rpx;
}

/* 输入框 */
.input-label {
  margin-bottom: 16rpx;
}
.text-input {
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(120, 160, 210, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

/* 釉面按钮 */
.glaze-btn {
  background: linear-gradient(135deg, #5C86C5, #7EA5D8);
  color: #ffffff;
  border-radius: var(--radius-capsule);
  box-shadow: 0 8rpx 24rpx rgba(92, 134, 197, 0.3), inset 0 2rpx 0 rgba(255,255,255,0.2);
  height: 72rpx;
  font-size: 28rpx;
  font-weight: 400;
  width: 100%;
}

/* 朱砂印章感退出 */
.seal-btn {
  margin-top: 64rpx;
  background: rgba(200, 70, 70, 0.04);
  color: #B54040;
  border: 1rpx solid rgba(181, 64, 64, 0.2);
  border-radius: var(--radius-capsule);
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 400;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 4rpx;
}

/* ================= 深色模式适配 ================= */
.page.dark .landscape-bg {
  /* 移除浅色背景图，使用纯净深色底色，或如果你有深色山水图可替换 */
  background: var(--color-bg);
}

.page.dark .text-title {
  color: var(--color-text-primary);
}

.page.dark .text-subtitle,
.page.dark .group-title {
  color: var(--color-text-secondary);
}

.page.dark .glass-card {
  background: rgba(10, 24, 43, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.3);
}

.page.dark .arrow-item text.arrow {
  color: rgba(255, 255, 255, 0.3);
}

.page.dark .divider {
  background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,0.06), rgba(255,255,255,0));
}

.page.dark .capsule-group {
  background: rgba(0, 0, 0, 0.2);
}

.page.dark .capsule-btn {
  color: var(--color-text-secondary);
}

.page.dark .capsule-btn.active {
  background: linear-gradient(135deg, #1A2E4C, #243B5C);
  color: #EDF5FF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.3);
}

.page.dark .text-input {
  background: rgba(0, 0, 0, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: var(--color-text-primary);
}

.page.dark .glaze-btn {
  background: linear-gradient(135deg, #243B5C, #1A2E4C);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.4), inset 0 2rpx 0 rgba(255,255,255,0.05);
  color: #EDF5FF;
}

.page.dark .seal-btn {
  background: rgba(200, 70, 70, 0.1);
  border: 1rpx solid rgba(181, 64, 64, 0.3);
  color: #E57373;
}
