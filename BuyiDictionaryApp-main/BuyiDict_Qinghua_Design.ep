          <Property name="textColor">#173B6C</Property>
          <Property name="textSize">12</Property>
          <Property name="textAlign">center</Property>
        </Element>

        <!-- 精选专题 Banner -->
        <Element id="Home_Banner_Title" type="Native.Text">
          <Property name="box">24,370,100,30</Property>
          <Property name="textContent">精选专题</Property>
          <Property name="textColor">#123B6B</Property>
          <Property name="textSize">20</Property>
          <Property name="fontWeight">bold</Property>
        </Element>
        <Element id="Home_Banner_Card" type="Native.Rectangle">
          <Property name="box">20,410,350,140</Property>
          <Property name="fillColor">#FFFFFF</Property>
          <Property name="radius">24</Property>
          <Property name="strokeColor">#5AA9FF</Property>
          <Property name="strokeWidth">1</Property> <!-- 亮蓝釉彩包边 -->
