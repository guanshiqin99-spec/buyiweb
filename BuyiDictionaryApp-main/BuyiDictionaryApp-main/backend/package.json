{
  "name": "buyi-dictionary-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend for Buyi Dictionary miniapp and admin web",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "admin:init": "ts-node src/scripts/init-admin.ts",
    "db:migrate": "typeorm-ts-node-commonjs migration:run -d src/typeorm-cli.config.ts",
    "seed:data": "ts-node --transpile-only src/scripts/seed-data.ts",
    "db:revert": "typeorm-ts-node-commonjs migration:revert -d src/typeorm-cli.config.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cos-nodejs-sdk-v5": "^2.14.7",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "mysql2": "^3.14.0",
    "pinyin-pro": "^3.27.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serverless-http": "^4.0.0",
    "sql.js": "^1.13.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.30",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
