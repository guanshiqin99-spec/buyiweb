/* 收藏页青花瓷风格样式 */

.header-section {
  margin-bottom: 32rpx;
}

/* 分段器 Segmented Control */
.segment-control {
  display: flex;
  background: var(--color-card-border);
  padding: 8rpx;
  border-radius: 16rpx;
  margin-bottom: 48rpx;
}

.page.dark .segment-control {
  background: rgba(255, 255, 255, 0.05); /* 修复在深色模式下的底色全黑 */
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  color: var(--color-text-secondary);
  font-size: 30rpx;
  transition: all 0.3s;
}
.seg-item.active {
  background: var(--color-card-bg);
  color: var(--color-primary);
  font-weight: bold;
  box-shadow: var(--shadow-light);
}

.page.dark .seg-item.active {
  background: rgba(43, 62, 92, 0.85); /* 胶囊选中时的暗色深蓝玻璃态 */
  color: #EDF5FF;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.3);
}

/* 列表卡片复用 */
.fav-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 文本卡片内部样式 */
.result-card {
  padding: 32rpx;
  margin-bottom: 0;
  box-shadow: none; /* 由 swipe-item 控制，内部不需要 shadow 避免被从外层 overflow: hidden 裁剪，也不用双层边框 */
  border: none;
}
.result-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.result-main {
  color: var(--color-primary-dark);
  margin-bottom: 16rpx;
  display: block;
}
.result-sub {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.fav-icon {
  font-size: 40rpx;
  color: var(--color-text-secondary);
}
.fav-icon.active {
  color: var(--color-primary);
}

/* 民歌卡片内部样式 */
.song-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 0;
  box-shadow: none;
  border: none;
}
.song-cover {
  width: 120rpx;
  height: 120rpx;
  background: var(--color-bg);
  border-radius: 16rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}
.song-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.song-title {
  margin-bottom: 8rpx;
}

/* 状态卡片 */
.status-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}
.status-card.empty {
  border-style: dashed;
  background: transparent;
  box-shadow: none;
}
.status-card .text-h3 {
  margin-bottom: 16rpx;
}
.login-btn {
  margin-top: 32rpx;
  width: 240rpx;
}

.page.dark .status-card.empty {
  border-color: rgba(255, 255, 255, 0.1);
}